# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# ADMOB CONFIGURATION
# Default test app and banner IDs
ADMOB_APP_ID=ca-app-pub-3940256099942544~3347511713
ADMOB_BANNER_ID=ca-app-pub-3940256099942544/6300978111

# FIREBASE PROGRAMMATIC CONFIG (Optional, avoids needing google-services.json)
FIREBASE_API_KEY=MY_FIREBASE_API_KEY
FIREBASE_APP_ID=MY_FIREBASE_APP_ID
FIREBASE_PROJECT_ID=MY_FIREBASE_PROJECT_ID

